// =============================================
// JENKINSFILE — Declarative Pipeline
// =============================================
// This file lives in your Git repo root.
// Jenkins reads it automatically when a build triggers.
//
// PIPELINE FLOW:
// Git Push → Jenkins detects → Runs this file → WAR built → Deployed to WebLogic/Tomcat
//
// HOW TO USE:
// 1. Push this file to GitHub along with your code
// 2. Create a Pipeline job in Jenkins
// 3. Set "Pipeline script from SCM" → Git → your repo URL
// 4. Jenkins will find this Jenkinsfile and run it
// =============================================

pipeline {

    // "agent any" = run on any available Jenkins node
    // In a real bank: agent { label 'linux-build-server' }
    agent any

    // =============================================
    // ENVIRONMENT VARIABLES
    // Accessible throughout the pipeline as env.VAR_NAME
    // Sensitive values (passwords) should come from
    // Jenkins Credentials store, NOT hardcoded here!
    // =============================================
    environment {
        APP_NAME        = 'DummyBankApp'
        WAR_FILE        = 'target/DummyBankApp.war'

        // Tomcat deploy settings (easier than WebLogic for local setup)
        TOMCAT_HOST     = 'localhost'           // Change to your EC2 IP
        TOMCAT_PORT     = '8080'
        TOMCAT_USER     = 'admin'
        TOMCAT_PASS     = credentials('tomcat-password')  // From Jenkins credentials store
        DEPLOY_PATH     = '/opt/tomcat/webapps'

        // WebLogic settings (if using WebLogic instead of Tomcat)
        // WL_HOST      = 'localhost'
        // WL_PORT      = '7001'
        // WL_USER      = 'weblogic'
        // WL_PASS      = credentials('weblogic-password')
    }

    // =============================================
    // PIPELINE STAGES
    // Each stage = one step in the CI/CD process
    // If any stage fails, pipeline stops and notifies
    // =============================================
    stages {

        // -----------------------------------------
        // STAGE 1: CHECKOUT
        // Pull latest code from Git repository
        // -----------------------------------------
        stage('Checkout') {
            steps {
                echo '📥 Pulling latest code from Git...'
                checkout scm   // "scm" = the Git config from Jenkins job settings

                // Print commit info for traceability
                sh 'git log --oneline -5'
                sh 'echo "Branch: $(git branch --show-current)"'
            }
        }

        // -----------------------------------------
        // STAGE 2: BUILD
        // Maven compiles Java code and packages WAR
        // "clean package" = delete old build, then build fresh
        // "-DskipTests" = skip tests here (we test in next stage)
        // -----------------------------------------
        stage('Build') {
            steps {
                echo '🔨 Building with Maven...'
                sh 'mvn clean package -DskipTests'

                // Verify WAR was created
                sh 'ls -lh target/*.war'
                echo "✅ Build successful: ${env.WAR_FILE}"
            }
        }

        // -----------------------------------------
        // STAGE 3: TEST
        // Run unit tests
        // In a real bank: also runs SonarQube, OWASP scan, etc.
        // -----------------------------------------
        stage('Test') {
            steps {
                echo '🧪 Running tests...'
                sh 'mvn test'
            }
            post {
                always {
                    // Publish test results in Jenkins UI
                    junit '**/target/surefire-reports/*.xml'
                }
            }
        }

        // -----------------------------------------
        // STAGE 4: ARCHIVE ARTIFACT
        // Save the WAR file in Jenkins so you can
        // download it or use it in later stages
        // -----------------------------------------
        stage('Archive Artifact') {
            steps {
                echo '📦 Archiving WAR file...'
                archiveArtifacts artifacts: 'target/*.war', fingerprint: true
                echo "WAR file archived: ${env.APP_NAME}-${BUILD_NUMBER}.war"
            }
        }

        // -----------------------------------------
        // STAGE 5: DEPLOY TO TOMCAT
        // Copy WAR file to Tomcat's webapps directory
        // Tomcat auto-deploys when it detects a new WAR
        //
        // Option A: SCP (copy over SSH) — simplest
        // Option B: Tomcat Manager API — cleaner
        // Option C: WebLogic WLST script — enterprise
        // -----------------------------------------
        stage('Deploy') {
            steps {
                echo '🚀 Deploying to Tomcat...'

                // Option A: SCP the WAR file to the server
                // Replace with your actual EC2 IP and SSH key
                sh """
                    scp -i ~/.ssh/bank-server.pem \
                        ${env.WAR_FILE} \
                        ubuntu@${env.TOMCAT_HOST}:${env.DEPLOY_PATH}/${env.APP_NAME}.war

                    echo "WAR deployed to ${env.TOMCAT_HOST}:${env.DEPLOY_PATH}"
                """

                // Wait for Tomcat to auto-deploy (usually 10-15 seconds)
                sh 'sleep 15'
            }
        }

        // -----------------------------------------
        // STAGE 6: SMOKE TEST
        // Quick check: is the app actually running?
        // Sends HTTP request, checks for 200 OK response
        // -----------------------------------------
        stage('Smoke Test') {
            steps {
                echo '💨 Running smoke test...'
                sh """
                    HTTP_CODE=\$(curl -s -o /dev/null -w "%{http_code}" \
                        http://${env.TOMCAT_HOST}:${env.TOMCAT_PORT}/${env.APP_NAME}/login)

                    echo "HTTP Response Code: \$HTTP_CODE"

                    if [ "\$HTTP_CODE" = "200" ]; then
                        echo "✅ Smoke test PASSED — App is live!"
                    else
                        echo "❌ Smoke test FAILED — HTTP \$HTTP_CODE"
                        exit 1
                    fi
                """
            }
        }

    }   // end stages

    // =============================================
    // POST ACTIONS
    // Run after all stages, regardless of success/failure
    // =============================================
    post {

        success {
            echo """
            ╔══════════════════════════════════════╗
            ║   ✅ PIPELINE SUCCESS                 ║
            ║   App: ${env.APP_NAME}               ║
            ║   Build: #${BUILD_NUMBER}            ║
            ║   URL: http://${env.TOMCAT_HOST}:${env.TOMCAT_PORT}/${env.APP_NAME}
            ╚══════════════════════════════════════╝
            """
            // In real setup: send email or Slack notification
            // mail to: 'team@bank.com', subject: "✅ Build #${BUILD_NUMBER} deployed"
        }

        failure {
            echo "❌ PIPELINE FAILED at stage: ${currentBuild.currentResult}"
            echo "Check console output for details."
            // mail to: 'team@bank.com', subject: "❌ Build #${BUILD_NUMBER} FAILED"
        }

        always {
            echo "Pipeline finished. Cleaning workspace..."
            cleanWs()   // Delete workspace files to free disk space
        }
    }

}
