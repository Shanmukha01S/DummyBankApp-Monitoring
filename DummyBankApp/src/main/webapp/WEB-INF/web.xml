<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <!--
    web.xml = Deployment Descriptor
    ================================
    This file tells WebLogic/Tomcat how to configure the application.
    - What is the app's display name?
    - Where does "/" route to? (welcome page)
    - Session timeout?
    - Error pages?

    Think of it as the "configuration manual" WebLogic reads
    before starting your app.
    -->

    <display-name>Dummy Bank Application</display-name>

    <!-- Default page when user visits root URL / -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Session timeout = 30 minutes of inactivity -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- Custom error pages — professional touch -->
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/views/error.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/WEB-INF/views/error.jsp</location>
    </error-page>

</web-app>
